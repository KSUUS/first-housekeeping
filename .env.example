# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; never commit real keys.
#
# All variables MUST start with VITE_ to be exposed to the frontend.

# ----- Supabase (chat backend) ---------------------------------------
# Get from Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# ----- Translation Edge Function URL ---------------------------------
# Usually: https://YOUR-PROJECT.supabase.co/functions/v1/translate
VITE_TRANSLATE_URL=https://YOUR-PROJECT.supabase.co/functions/v1/translate
